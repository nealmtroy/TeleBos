# TeleBos Backend Environment Variables
# Copy this to .env and fill in your values

DEBUG=False
PRODUCTION=False       # Set True in production — enables Secure cookies, HSTS, etc.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telebos
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/telebos
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT (change in production!)
JWT_SECRET_KEY=change-this-secret-key-in-production

# Encryption key (32 base64-encoded bytes)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=VV4UT9poR1AcJvMaReHkhvkfKMMsCp8lIrovWMxMcJA=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Uptimerobot
UPTIMEROBOT_API_KEY=isi_api_key_dari_uptimerobot

# Telegram API credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# Default destination for broadcast cycle logs (sent by the broadcasting account itself)
BROADCAST_LOG_DEFAULT_DEST=@teleboslogging_bot

# SMM Panel (Buzzerpanel.id) — get from buzzerpanel.id profile
SMM_API_URL=https://buzzerpanel.id/api/json.php
SMM_API_KEY=
SMM_SECRET_KEY=
