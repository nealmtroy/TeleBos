# ============================================
# TeleBos — Multi-Account Telegram Manager
# ============================================
PRODUCTION=False
DEBUG=True

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgress-password-default
POSTGRES_DB=telebos
DATABASE_URL=postgresql+asyncpg://postgres:postgress-password-default@postgres:5432/telebos
DATABASE_URL_SYNC=postgresql://postgres:postgress-password-default@postgres:5432/telebos

# --- Redis ---
REDIS_PASSWORD=change-redis-secret-in-production
REDIS_URL=redis://:change-redis-secret-in-production@redis:6379/0
CELERY_BROKER_URL=redis://:change-redis-secret-in-production@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-redis-secret-in-production@redis:6379/2

# --- Backend ---
APP_SECRET_KEY=change-me-to-a-random-secret-string-at-least-32-chars
ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# --- Better Auth (Frontend/Next.js) ---
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# --- CORS ---
# Format JSON array. Tambah semua origin yang legitimate.
# Contoh production: CORS_ORIGINS=["http://localhost:3000", "https://example.com"]
CORS_ORIGINS=["http://localhost:3000"]

# --- Telegram API & Bot ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=

# --- UptimeRobot ---
UPTIMEROBOT_API_KEY=
UPTIMEROBOT_MONITOR_IDS=

# --- Broadcast ---
BROADCAST_LOG_DEFAULT_DEST=@teleboslogging_bot

# --- SMM Panel ---
SMM_API_URL=https://buzzerpanel.id/api/json.php
SMM_API_KEY=
SMM_SECRET_KEY=

# --- Frontend (NEXT_PUBLIC_* dibaca di browser, harus di-set juga) ---
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=dikn5vvaNkzkAn/vu+hTSmAJS/1n/RYxtlcWrt7kINM=
