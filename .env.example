# ============================================
# TeleBos — Multi-Account Telegram Manager
# ============================================
# Copy file ini ke .env dan isi nilainya.
# Semua service (backend, frontend, celery, bot) baca dari root .env ini.

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=telebos_secret_change_me
POSTGRES_DB=telebos
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Redis ---
REDIS_PASSWORD=change-redis-secret-in-production
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# --- Backend ---
PRODUCTION=False
DEBUG=True
JWT_SECRET_KEY=change-me-to-a-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# --- Better Auth (Frontend/Next.js) ---
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Telegram API & Bot ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=

# --- UptimeRobot ---
UPTIMEROBOT_API_KEY=
UPTIMEROBOT_MONITOR_IDS=

# --- Broadcast ---
BROADCAST_LOG_DEFAULT_DEST=@teleboslogging_bot

# --- SMM Panel ---
SMM_API_URL=https://buzzerpanel.id/api/json.php
SMM_API_KEY=
SMM_SECRET_KEY=

# --- Frontend (NEXT_PUBLIC_* dibaca di browser, harus di-set juga) ---
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
