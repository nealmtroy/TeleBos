# ============================================
# TeleBos — Multi-Account Telegram Manager
# ============================================

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=telebos
POSTGRES_USER=telebos
POSTGRES_PASSWORD=telebos_secret_change_me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Backend ---
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# --- Telegram API (optional — Telethon uses its own defaults) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
